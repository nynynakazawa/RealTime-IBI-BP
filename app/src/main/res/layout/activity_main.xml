<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1e3333">

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="96dp"
            android:paddingEnd="16dp"
            android:paddingBottom="28dp">

            <ImageView
                android:id="@+id/appIcon"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="20dp"
                android:contentDescription="App Icon"
                android:src="@mipmap/ic_launcher_foreground"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/appTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="RealTime-HR/BP"
                android:textColor="#78CCCC"
                android:textSize="30sp"
                app:layout_constraintBottom_toBottomOf="@id/appIcon"
                app:layout_constraintStart_toEndOf="@id/appIcon"
                app:layout_constraintTop_toTopOf="@id/appIcon" />

            <TextView
                android:id="@+id/labelMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Select Processing Mode："
                android:textColor="#78CCCC"
                android:textSize="20sp"
                app:layout_constraintEnd_toStartOf="@id/spinnerLogicSelection"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appIcon" />

            <Spinner
                android:id="@+id/spinnerLogicSelection"
                style="@style/CustomSpinnerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBaseline_toBaselineOf="@id/labelMode"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/labelMode" />

            <LinearLayout
                android:id="@+id/FileNameAndMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center|top"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/labelMode">

                <EditText
                    android:id="@+id/editTextName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Enter FileName"
                    android:textColor="#78CCCC"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mode : -1"
                    android:textColor="#78CCCC"
                    android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/oscillometricGuideCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_phase_panel"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="12dp"
                android:paddingEnd="14dp"
                android:paddingBottom="14dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/FileNameAndMode">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPhaseStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="phase0 配置"
                        android:textColor="#D8FFF2"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/signalQualityIndicator"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_signal_quality_indicator" />

                    <TextView
                        android:id="@+id/tvQualityStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:singleLine="true"
                        android:text="品質 WAIT  A:OK  Exp:OK  Pos:NG  Touch:OFF"
                        android:textColor="#BDE6D8"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTargetProgressLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="目標 phase2開始後"
                    android:textColor="#C4EEDC"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/pressTargetBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="5dp"
                    android:indeterminate="false"
                    android:max="1000"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_flat_green" />

                <TextView
                    android:id="@+id/tvCurrentProgressLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="現在 0 px^2"
                    android:textColor="#C4EEDC"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/pressCurrentBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="5dp"
                    android:indeterminate="false"
                    android:max="1000"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_flat_cyan" />
            </LinearLayout>

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/lineChart"
                android:layout_width="0dp"
                android:layout_height="350dp"
                android:layout_marginTop="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/oscillometricGuideCard" />

            <TextView
                android:id="@+id/NowTextMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="キャリブレーション中"
                android:textColor="#78CCCC"
                android:textSize="20sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lineChart" />

            <TableLayout
                android:id="@+id/Table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="#78CCCC"
                android:showDividers="middle"
                android:stretchColumns="*"
                app:layout_constraintTop_toBottomOf="@id/NowTextMessage">

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/greenValueTextView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Green : " android:textColor="#78CCCC" android:textSize="20sp" />
                    <TextView android:id="@+id/BPMSD" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BPM SD : " android:textColor="#78CCCC" android:textSize="20sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/ibiTextView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IBI : " android:textColor="#78CCCC" android:textSize="20sp" />
                    <TextView android:id="@+id/HRTextView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HeartRate : " android:textColor="#78CCCC" android:textSize="20sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/SmoothedIbiTextView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IBI(Smooth) : " android:textColor="#78CCCC" android:textSize="20sp" />
                    <TextView android:id="@+id/SmoothedHRTextView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HR(Smooth) : " android:textColor="#78CCCC" android:textSize="20sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvSBPRealtime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SBP : --" android:textColor="#78CCCC" android:textSize="20sp" />
                    <TextView android:id="@+id/tvDBPRealtime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DBP : --" android:textColor="#78CCCC" android:textSize="20sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvSBPAvg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SBP(Average) : --" android:textColor="#78CCCC" android:textSize="20sp" />
                    <TextView android:id="@+id/tvDBPAvg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DBP(Average) : --" android:textColor="#78CCCC" android:textSize="20sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvSinSBP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SinSBP(D) : --" android:textColor="#FF9966" android:textSize="20sp" />
                    <TextView android:id="@+id/tvSinDBP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SinDBP(D) : --" android:textColor="#FF9966" android:textSize="20sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvSinSBPAvg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SinSBP(D)(Avg) : --" android:textColor="#FF9966" android:textSize="20sp" />
                    <TextView android:id="@+id/tvSinDBPAvg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SinDBP(D)(Avg) : --" android:textColor="#FF9966" android:textSize="20sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvSinSBPM" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SinSBP(M) : --" android:textColor="#99FF99" android:textSize="20sp" />
                    <TextView android:id="@+id/tvSinDBPM" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SinDBP(M) : --" android:textColor="#99FF99" android:textSize="20sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvSinSBPAvgM" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SinSBP(M)(Avg) : --" android:textColor="#99FF99" android:textSize="20sp" />
                    <TextView android:id="@+id/tvSinDBPAvgM" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SinDBP(M)(Avg) : --" android:textColor="#99FF99" android:textSize="20sp" />
                </TableRow>
            </TableLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/show_mode_select_fragment_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Mode"
                android:textColor="#78CCCC"
                android:textSize="20sp"
                app:layout_constraintEnd_toStartOf="@id/start_button"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/Table" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/start_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="16dp"
                android:text="Start"
                android:textColor="#78CCCC"
                android:textSize="20sp"
                app:layout_constraintEnd_toStartOf="@id/reset_button"
                app:layout_constraintStart_toEndOf="@id/show_mode_select_fragment_button"
                app:layout_constraintTop_toBottomOf="@id/Table" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/reset_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="16dp"
                android:text="Reset"
                android:textColor="#78CCCC"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/start_button"
                app:layout_constraintTop_toBottomOf="@id/Table" />

            <TableLayout
                android:id="@+id/cameraInfoTable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#1A78CCCC"
                android:padding="8dp"
                android:stretchColumns="*"
                app:layout_constraintTop_toBottomOf="@id/reset_button">

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Camera X API Info" android:textColor="#78CCCC" android:textSize="18sp" android:textStyle="bold" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvFNumber" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F-Number: --" android:textColor="#78CCCC" android:textSize="16sp" />
                    <TextView android:id="@+id/tvISO" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ISO: --" android:textColor="#78CCCC" android:textSize="16sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvExposureTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Exposure: --" android:textColor="#78CCCC" android:textSize="16sp" />
                    <TextView android:id="@+id/tvColorTemperature" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Color Temp: --" android:textColor="#78CCCC" android:textSize="16sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvWhiteBalance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WB Mode: --" android:textColor="#78CCCC" android:textSize="16sp" />
                    <TextView android:id="@+id/tvFocusDistance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Focus: --" android:textColor="#78CCCC" android:textSize="16sp" />
                </TableRow>

                <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/tvAperture" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aperture: --" android:textColor="#78CCCC" android:textSize="16sp" />
                    <TextView android:id="@+id/tvSensorSensitivity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sensor: --" android:textColor="#78CCCC" android:textSize="16sp" />
                </TableRow>
            </TableLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/touchCaptureOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no"
        android:translationZ="12dp">

        <View
            android:id="@+id/statusBarTouchBlocker"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_gravity="top"
            android:background="@color/green_color"
            android:clickable="true"
            android:focusable="false"
            android:importantForAccessibility="no" />

        <View
            android:id="@+id/cameraHoleMarker"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="top|center_horizontal"
            android:background="@drawable/bg_camera_hole_marker" />

        <View
            android:id="@+id/illuminationRingView"
            android:layout_width="142dp"
            android:layout_height="76dp"
            android:layout_gravity="top|center_horizontal"
            android:background="@drawable/bg_touch_ring" />

        <View
            android:id="@+id/landingZoneView"
            android:layout_width="104dp"
            android:layout_height="54dp"
            android:layout_gravity="top|center_horizontal"
            android:background="@drawable/bg_landing_zone" />

        <TextView
            android:id="@+id/landingZoneLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:includeFontPadding="false"
            android:text="指先をここに"
            android:textColor="#E9FFF4"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/landingInstructionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:includeFontPadding="false"
            android:text="フロントカメラの少し下"
            android:textColor="#9EC8B7"
            android:textSize="11sp" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/mode_select_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:elevation="16dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:translationZ="16dp"
        android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
